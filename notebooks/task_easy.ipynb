        "#    - надрукуйте і прочитайте: що найсильніше пов'язане з ціною?\n",
        "\n",
        "\n",
        "num = clean.select_dtypes(\"number\")\n",
        "num.corr()['Price'].drop(\"Price\").sort_values(key=abs, ascending=False).round(3)"
